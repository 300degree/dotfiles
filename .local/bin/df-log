#! /usr/bin/env bash

if [[ "$(uname)" == "Darwin" || "$(uname)" == "darwin" ]]; then
    CPY="pbcopy"
elif [[ "$(uname)" == "Linux" || "$(uname)" == "linux" ]]; then
    CPY="xclip -selection clipboard"
fi

git log                                                                        \
    --graph                                                                    \
    --color=always                                                             \
    --format='%C(white)%h %C(blue)%s%C(red)%d'                                 |
fzf                                                                            \
    --reverse                                                                  \
    --no-multi                                                                 \
    --no-sort                                                                  \
    --ansi                                                                     \
    --preview='echo {}                                                         |
               grep -o "[a-f0-9]\{5\}"                                         |
               head -1                                                         |
               xargs -I % sh -c "git show --color=always %"'                   \
    --header='<Enter>: view, <C-c>: copy hash'                                 \
    --bind='enter:execute(hash=$(echo {}                                       |
            grep -o "[a-f0-9]\{7\}"                                            |
            sed -n "1p")                                                       \
            && [[ $hash != "" ]]                                               \
            && sh -c "git show --color $hash                                   |
            less -R")'                                                         \
    --bind='ctrl-c:execute(hash=$(echo {}                                      |
            grep -o "[a-f0-9]\{7\}")                                           \
            && echo -n $hash | $CPY)'
